#!/usr/bin/env bash
# Pre-commit hook installed by tools/setup-hooks.sh
# Local enforcement of Tier 4 rules from docs/systems/agent-guardrails.md
#
# Refuses:
#   1. Agent commits from the shared primary checkout (use a linked worktree)
#   2. Commits to main or master (Tier 4: never push to main directly)
#   3. .env or .env.* files (Tier 4: never commit secrets)
#   4. macOS duplicates ("file 2.md" pattern — filesystem artifacts)
#   5. Commits under a non-canonical git identity (Vercel deploy gate)
# Warns (does not refuse):
#   6. New files at workspace root not on the allowlist (CLAUDE.md File Discipline)
#
# To bypass in an emergency: git commit --no-verify
# (Don't bypass routinely. If you find yourself bypassing often, fix the rule
# rather than working around it.)

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

err()  { echo -e "${RED}pre-commit ERROR:${NC} $*" >&2; }
warn() { echo -e "${YELLOW}pre-commit WARN:${NC}  $*" >&2; }
ok()   { echo -e "${GREEN}pre-commit OK:${NC}    $*" >&2; }

repo_abs_path() {
    local p="$1"
    case "$p" in
        /*) printf '%s\n' "$p" ;;
        *) printf '%s\n' "$(pwd -P)/$p" ;;
    esac
}

# ---- 1. Refuse commits from the shared primary checkout ----
# In the primary checkout, Git's per-worktree git dir and common git dir are
# the same. In a linked worktree, --git-dir is <common>/worktrees/<name>, while
# --git-common-dir stays the shared common repo. This catches the exact failure
# mode where another session moves the shared checkout's HEAD mid-commit.
if [ "${ALLOW_SHARED_COMMIT:-}" != "1" ]; then
    GIT_DIR_ABS="$(repo_abs_path "$(git rev-parse --git-dir)")"
    GIT_COMMON_DIR_ABS="$(repo_abs_path "$(git rev-parse --git-common-dir)")"
    if [ "$GIT_DIR_ABS" = "$GIT_COMMON_DIR_ABS" ]; then
        err "Refusing commit from the shared primary checkout."
        err "Agents must commit from an isolated linked worktree:"
        err "  bash tools/new-worktree.sh codex/<topic>-$(date +%F)"
        err "Human override, when deliberate:"
        err "  ALLOW_SHARED_COMMIT=1 git commit ..."
        exit 1
    fi
fi

# ---- 2. Refuse commits to main or master directly ----
BRANCH=$(git branch --show-current 2>/dev/null || echo "")
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
    err "Refusing commit to '$BRANCH' (Tier 4: agent-guardrails.md §2)."
    err "Branch off main first:"
    err "  git checkout -b <topic>-$(date +%Y-%m-%d) origin/main"
    err "Then commit on the branch and open a PR."
    exit 1
fi

# ---- 3. Refuse .env or .env.* files ----
ENV_FILES=$(git diff --cached --name-only --diff-filter=AM 2>/dev/null | grep -E '(^|/)\.env($|\.)' || true)
if [ -n "$ENV_FILES" ]; then
    err "Refusing to commit secrets file(s) — Tier 4:"
    echo "$ENV_FILES" | sed 's/^/  - /' >&2
    err "If a secret has already leaked into git history, rotate it immediately"
    err "and remove from history with git filter-repo or BFG."
    exit 1
fi

# ---- 4. Refuse macOS duplicates ----
DUPES=$(git diff --cached --name-only --diff-filter=AM 2>/dev/null | grep -E ' [0-9]+\.' || true)
if [ -n "$DUPES" ]; then
    err "Refusing to commit macOS duplicate file(s):"
    echo "$DUPES" | sed 's/^/  - /' >&2
    err "These are filesystem artifacts (e.g. 'Finder duplicates'), never real work."
    err "Delete them before committing."
    exit 1
fi

# ---- 5. Refuse commits under a non-canonical git identity ----
# Why this is a hard refuse: Vercel project access is gated by GitHub identity.
# Commits authored by a personal account (e.g. vboguta@gmail.com / mamyteJ) get
# rejected by the Vercel deploy gate, and — critically — every PR the Loop Runner
# itself opens would fail the same gate. The canonical identity per CLAUDE.md's
# "Git Identity" section is the only one with Vercel + federation-peer access.
CANONICAL_NAME="LietuvaAI"
CANONICAL_EMAIL="vilija@lietuva.ai"
ACTUAL_NAME=$(git config user.name 2>/dev/null || echo "")
ACTUAL_EMAIL=$(git config user.email 2>/dev/null || echo "")
if [ "$ACTUAL_EMAIL" != "$CANONICAL_EMAIL" ] || [ "$ACTUAL_NAME" != "$CANONICAL_NAME" ]; then
    err "Refusing commit under non-canonical git identity (Vercel deploy gate)."
    err "  Current:   ${ACTUAL_NAME:-(unset)} <${ACTUAL_EMAIL:-(unset)}>"
    err "  Required:  $CANONICAL_NAME <$CANONICAL_EMAIL>"
    err "Per CLAUDE.md 'Git Identity' section. Fix in this checkout with:"
    err "  git config --local user.name \"$CANONICAL_NAME\""
    err "  git config --local user.email \"$CANONICAL_EMAIL\""
    err "Then re-run the commit. (Verify: git config user.name && git config user.email)"
    exit 1
fi

# ---- 6. Warn on new files at workspace root not on the allowlist ----
# Allowlist of files permitted at workspace root. Add here ONLY if intentional.
ALLOWED_ROOT_PATTERN='^(CLAUDE\.md|ARCHITECTURE\.md|ARCHITECTURE-ENTITY-GRAPH\.md|DECISIONS\.md|INBOX\.md|TASKS\.md|README\.md|SESSION-HANDOFF.*\.md|LICENSE.*|\.gitignore|\.gitattributes|\.vercelignore|\.env\.example|\.env\.siteground|\.env\.local\.bak|vercel\.json|package\.json|package-lock\.json|yarn\.lock|pnpm-lock\.yaml|requirements\.txt|Pipfile|Pipfile\.lock|systems-dashboard\.html)$'

NEW_ROOT_FILES=$(git diff --cached --name-only --diff-filter=A 2>/dev/null | grep -v '/' | grep -Ev "$ALLOWED_ROOT_PATTERN" || true)
if [ -n "$NEW_ROOT_FILES" ]; then
    warn "New file(s) at workspace root (per CLAUDE.md File Discipline, prefer docs/<category>/):"
    echo "$NEW_ROOT_FILES" | sed 's/^/  - /' >&2
    warn "Continuing anyway. If intentional, add to allowlist in tools/git-hooks/pre-commit."
fi

exit 0
